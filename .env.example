# API (native PostgreSQL: install 15+ locally, create user + DB — see docs/INSTALL.md)
CM_HTTP_ADDR=0.0.0.0:8080
# URL must match the role, password, and database you created in Postgres (psql / pgAdmin).
# Windows: same URL shape; if Postgres listens on a custom port, use :5433 etc.
CM_DATABASE_URL=postgres://cloudmanager:cloudmanager@127.0.0.1:5432/cloudmanager?sslmode=disable
# Optional — app does not require Redis to run; leave unset if unused.
# CM_REDIS_ADDR=127.0.0.1:6379
CM_SESSION_SECRET=change-me-to-32-bytes-minimum-secret
CM_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CM_OIDC_ISSUER=https://your-idp/realms/master
CM_OIDC_CLIENT_ID=cloudmanager
CM_OIDC_CLIENT_SECRET=
CM_OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
CM_BASE_URL=http://localhost:8080
CM_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
CM_TRUSTED_PROXIES=
CM_TERRAFORM_PATH=terraform
# On Windows dev, e.g. CM_WORKDIR=C:\tmp\cloudmanager (create folder first).
CM_WORKDIR=/var/lib/cloudmanager
CM_WEB_ROOT=
CM_DEV_BEARER=
CM_CONFIG=
CM_DISABLE_OIDC=1

# Worker
CM_WORKER_CONCURRENCY=2

# Dev: skip OIDC and use a bootstrap platform admin (see migrations)
CM_DEV_BOOTSTRAP=1
